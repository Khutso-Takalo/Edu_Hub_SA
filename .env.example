VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ENABLE_CHAT_LEARNING_SYNC=false
VITE_GOOGLE_CUSTOM_SEARCH_API_KEY=
VITE_GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
VITE_GOOGLE_CUSTOM_SEARCH_BASE_URL=https://customsearch.googleapis.com/customsearch/v1

# Monitoring & Error Tracking
VITE_SENTRY_DSN=
VITE_LOGGING_URL=

# Notification Webhooks
# Set to your deployed webhook endpoint (e.g., https://your-project.vercel.app/api/webhooks/notifications)
# Or use channel-specific URLs to override the catch-all webhook
VITE_NOTIFICATION_WEBHOOK_URL=
VITE_NOTIFICATION_EMAIL_WEBHOOK_URL=
VITE_NOTIFICATION_SMS_WEBHOOK_URL=

# SendGrid Configuration (for email delivery)
VITE_SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=notifications@yourdomain.com

# Twilio Configuration (for SMS delivery)
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
VITE_TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
VITE_TWILIO_PHONE_NUMBER=+1234567890

# Notification reliability tuning
VITE_NOTIFICATION_MAX_ATTEMPTS=3
VITE_NOTIFICATION_BASE_DELAY_MS=400
VITE_NOTIFICATION_SLO_TARGET_PERCENT=99
VITE_NOTIFICATION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
VITE_NOTIFICATION_CIRCUIT_BREAKER_COOLDOWN_MS=60000

# Background verification scheduler
VITE_ENABLE_BACKGROUND_VERIFICATION=true
VITE_VERIFICATION_INTERVAL_MINUTES=60
VITE_VERIFICATION_BATCH_SIZE=10

# Optional: Webhook request signature secret (for security)
WEBHOOK_SIGNATURE_SECRET=your-secret-key-here

